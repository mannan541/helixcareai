# Mobile — LOCAL DEVELOPMENT. Copy to .env for local runs.
# Use this for: flutter run (Chrome), iOS/macOS simulator (localhost).
# Android emulator: use API_BASE_URL=http://10.0.2.2:3000
#
# PRODUCTION: Do not use this file. CI and production builds use .env.production
# (production API base URL). Keep .env for local only.
API_BASE_URL=http://localhost:3000
