# Backend — LOCAL DEVELOPMENT ONLY. Copy to .env or .env.development.local.
# For PRODUCTION (Vercel), set variables in Vercel Project → Settings → Environment Variables (Production).

NODE_ENV=development
PORT=3000

# PostgreSQL
# Local: use Docker (default below) OR paste your Neon/remote URL so you don't need local Postgres.
# Vercel: add Postgres from Marketplace (e.g. Neon); it injects POSTGRES_URL — no need to set DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helixcareai
# Example Neon (for local dev without Docker): DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI for RAG (embeddings + chat)
OPENAI_API_KEY=sk-your-openai-api-key

# Embedding model dimension (OpenAI text-embedding-3-small = 1536)
EMBEDDING_DIMENSION=1536
