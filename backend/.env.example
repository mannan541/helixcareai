NODE_ENV=development
PORT=3000

# PostgreSQL (use same as docker-compose or your DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helixcareai

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI for RAG (embeddings + chat)
OPENAI_API_KEY=sk-your-openai-api-key

# Embedding model dimension (OpenAI text-embedding-3-small = 1536)
EMBEDDING_DIMENSION=1536
