# Production environment variables — set these in Vercel:
# Project → Settings → Environment Variables → Production (and Preview if needed).
# Do NOT commit real values. This file is a checklist only.

NODE_ENV=production
PORT=3000

# Database (Vercel Postgres / Neon: use POSTGRES_URL or DATABASE_URL)
# POSTGRES_URL=
# DATABASE_URL=

# JWT — use a long random secret in production
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# OpenAI for RAG
# OPENAI_API_KEY=

# Optional: embedding service, Ollama (if you host them)
# EMBEDDING_SERVICE_URL=
# OLLAMA_URL=
# OLLAMA_MODEL=
